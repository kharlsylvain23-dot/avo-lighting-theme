<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="{{ settings.primary }}">
    <link rel="canonical" href="{{ canonical_url }}">
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}

    {{ content_for_header }}

    <script>
      // Apply saved theme before paint to avoid FOUC.
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          if (!saved) {
            saved = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          if (saved === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
        } catch (e) {}
      })();
    </script>

    <style>
      :root {
        --color-primary: {{ settings.primary | default: '#111111' }};
        --color-secondary: {{ settings.secondary | default: '#ffffff' }};
        --color-gray: {{ settings.gray | default: '#e5e5e5' }};
        --color-accent: {{ settings.accent | default: '#ffe066' }};
        --font-body: {{ settings.body_font.family | default: 'system-ui' }}, {{ settings.body_font.fallback_families | default: 'sans-serif' }};
        --font-heading: {{ settings.heading_font.family | default: 'system-ui' }}, {{ settings.heading_font.fallback_families | default: 'sans-serif' }};
      }
    </style>

    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'theme.js' | asset_url }}" defer></script>
  </head>
  <body class="template-{{ template | replace: '.', '-' | handle }}">
    <a class="skip-link" href="#main">{{ 'general.accessibility.skip_to_content' | t }}</a>

    {% sections 'header-group' %}

    <main id="main" role="main">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}
  </body>
</html>
