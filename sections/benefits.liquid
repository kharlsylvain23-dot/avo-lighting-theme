<section class="benefits">
  <div class="benefits__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="benefits__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <ul class="benefits__grid">
      {%- for block in section.blocks -%}
        <li class="benefit" {{ block.shopify_attributes }}>
          <h3 class="benefit__title">{{ block.settings.title }}</h3>
          <p class="benefit__desc">{{ block.settings.description }}</p>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "Benefits",
  "tag": "section",
  "class": "section-benefits",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why our lamp" }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        { "type": "text",     "id": "title",       "label": "Title", "default": "Free shipping" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "On all orders, always." }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Benefits",
      "blocks": [
        { "type": "benefit" },
        { "type": "benefit", "settings": { "title": "5-year warranty", "description": "Built to last a decade or more." } },
        { "type": "benefit", "settings": { "title": "30-day returns", "description": "Love it or send it back." } }
      ]
    }
  ]
}
{% endschema %}