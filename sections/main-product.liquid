<section class="product-main">
  <div class="product-main__inner">
    <div class="product-main__media">
      {%- if product.featured_image -%}
        <img src="{{ product.featured_image | image_url: width: 1400 }}"
             alt="{{ product.featured_image.alt | default: product.title | escape }}"
             width="700" height="auto" loading="eager">
      {%- else -%}
        <img src="https://images.unsplash.com/photo-1513506003901-1e6a229e2d15?auto=format&fit=crop&w=1400&q=80"
             alt="{{ product.title | default: 'Lamp' | escape }}"
             width="700" height="auto" loading="eager" referrerpolicy="no-referrer">
      {%- endif -%}

      {%- if product.images.size > 1 -%}
        <ul class="product-main__thumbs">
          {%- for image in product.images limit: 6 -%}
            <li><img src="{{ image | image_url: width: 200 }}" alt="" width="100" height="auto" loading="lazy"></li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    <div class="product-main__details">
      {%- if section.settings.eyebrow != blank -%}
        <p class="product-main__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h1 class="product-main__title">{{ product.title | default: section.settings.fallback_title }}</h1>
      {%- if section.settings.subtitle != blank -%}
        <p class="product-main__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
      <p class="product-main__price">{{ product.price | default: section.settings.fallback_price | money }}</p>

      {%- if product.description != blank -%}
        <div class="product-main__desc rte">{{ product.description }}</div>
      {%- elsif section.settings.fallback_description != blank -%}
        <div class="product-main__desc rte">{{ section.settings.fallback_description }}</div>
      {%- endif -%}

      {%- form 'product', product, id: 'product-form', class: 'product-main__form' -%}
        {%- if product.has_only_default_variant == false -%}
          {%- for option in product.options_with_values -%}
            <label class="product-main__option-label" for="option-{{ forloop.index }}">{{ option.name }}</label>
            <select id="option-{{ forloop.index }}" name="options[{{ option.name | escape }}]">
              {%- for value in option.values -%}
                <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
              {%- endfor -%}
            </select>
          {%- endfor -%}
        {%- endif -%}

        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

        <div class="product-main__qty">
          <label for="qty">Qty</label>
          <input id="qty" type="number" name="quantity" value="1" min="1">
        </div>

        <button type="submit" name="add" class="cta product-main__add"
          {% if product != blank and product.selected_or_first_available_variant.available == false %}disabled{% endif %}>
          {%- if product == blank or product.selected_or_first_available_variant.available -%}
            {{ section.settings.cta_text | default: 'Add to cart' }}
          {%- else -%}
            Sold out
          {%- endif -%}
        </button>
      {%- endform -%}

      {%- if section.settings.show_trust -%}
        <ul class="product-main__trust">
          <li><strong>30-night trial</strong><span>full refund, free returns</span></li>
          <li><strong>5-year warranty</strong><span>anything fails, we replace it</span></li>
          <li><strong>Bulb included</strong><span>2700K spiral filament</span></li>
          <li><strong>Free shipping</strong><span>tracked, 3&ndash;5 business days</span></li>
        </ul>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="product-main__details-list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'detail' -%}
              <details class="product-main__detail" {{ block.shopify_attributes }}>
                <summary>{{ block.settings.heading }}</summary>
                <div class="rte">{{ block.settings.content }}</div>
              </details>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product",
  "tag": "section",
  "class": "section-product",
  "settings": [
    { "type": "text",     "id": "eyebrow",              "label": "Eyebrow",          "default": "" },
    { "type": "text",     "id": "subtitle",             "label": "Subtitle",         "default": "" },
    { "type": "text",     "id": "cta_text",             "label": "CTA text",         "default": "Add to cart" },
    { "type": "checkbox", "id": "show_trust",            "label": "Show trust strip", "default": true },
    { "type": "header",   "content": "Demo fallbacks (used when product is blank)" },
    { "type": "text",     "id": "fallback_title",        "label": "Fallback title",        "default": "The Halo" },
    { "type": "number",   "id": "fallback_price",        "label": "Fallback price (cents)", "default": 24900 },
    { "type": "richtext", "id": "fallback_description",  "label": "Fallback description" }
  ],
  "blocks": [
    {
      "type": "detail",
      "name": "Detail accordion",
      "settings": [
        { "type": "text",     "id": "heading", "label": "Heading", "default": "Details" },
        { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Detail copy.</p>" }
      ]
    },
    { "type": "@app" }
  ],
  "presets": [{ "name": "Product" }]
}
{% endschema %}
