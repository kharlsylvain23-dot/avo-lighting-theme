<section class="showcase">
  <div class="showcase__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="showcase__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- assign source = section.settings.collection -%}
    {%- if source != blank and section.blocks.size == 0 -%}
      <ul class="showcase__grid">
        {%- for product in collections[source].products limit: section.settings.limit -%}
          <li>{% render 'product-card', product: product %}</li>
        {%- endfor -%}
      </ul>
    {%- else -%}
      <ul class="showcase__grid">
        {%- for block in section.blocks -%}
          {%- assign product = all_products[block.settings.product] -%}
          <li {{ block.shopify_attributes }}>{% render 'product-card', product: product %}</li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Product showcase",
  "tag": "section",
  "class": "section-showcase",
  "settings": [
    { "type": "text",       "id": "heading",    "label": "Heading", "default": "Best sellers" },
    { "type": "collection", "id": "collection", "label": "Collection (optional)" },
    { "type": "range",      "id": "limit",      "label": "Max products from collection", "min": 2, "max": 12, "step": 1, "default": 4 }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" }
      ]
    },
    { "type": "@app" }
  ],
  "max_blocks": 12,
  "presets": [
    { "name": "Product showcase" }
  ]
}
{% endschema %}