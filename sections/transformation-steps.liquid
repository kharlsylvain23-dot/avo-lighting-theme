<section class="steps">
  <div class="steps__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="steps__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <ol class="steps__list">
      {%- for block in section.blocks -%}
        <li class="steps__item" {{ block.shopify_attributes }}>
          <span class="steps__num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
          <h3 class="steps__title">{{ block.settings.title }}</h3>
          <p class="steps__desc">{{ block.settings.description }}</p>
        </li>
      {%- endfor -%}
    </ol>
  </div>
</section>

{% schema %}
{
  "name": "Transformation steps",
  "tag": "section",
  "class": "section-steps",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Transform your space" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        { "type": "text",     "id": "title",       "label": "Title", "default": "Choose your lamp" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Pick the size and finish that suits your room." }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Transformation steps",
      "blocks": [
        { "type": "step" },
        { "type": "step", "settings": { "title": "Place it",  "description": "Set it on a desk, console, or shelf." } },
        { "type": "step", "settings": { "title": "Glow on",   "description": "Tap to dim. Sleep, work, and host beautifully." } }
      ]
    }
  ]
}
{% endschema %}